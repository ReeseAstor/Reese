# Email Configuration (SMTP)
# For Gmail, you'll need to use an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Application Configuration
PORT=3000
BASE_URL=http://localhost:3000

# Admin Authentication
# IMPORTANT: Change these in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS Configuration (comma-separated list of allowed origins)
# Leave empty or set to * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3000,https://reeseastor.com

# Production Configuration
# When deploying, update BASE_URL to your production domain
# BASE_URL=https://reeseastor.com
# ALLOWED_ORIGINS=https://reeseastor.com
