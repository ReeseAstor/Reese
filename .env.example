# Email Configuration (SMTP)
# For Gmail, you'll need to use an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Application Configuration
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Security Configuration
SESSION_SECRET=your-random-secret-key-here
ADMIN_PASSWORD=admin123
ALLOWED_ORIGINS=http://localhost:3000,https://reeseastor.com

# Production Configuration
# When deploying, update BASE_URL to your production domain
# BASE_URL=https://reeseastor.com
# NODE_ENV=production
# Generate a strong SESSION_SECRET: openssl rand -base64 32
# Change ADMIN_PASSWORD to a strong password
